# Credenciales de PostgreSQL usadas por el servicio `postgres` de
# docker-compose.yml (vía env_file, ver ahí). El backend se conecta a la misma
# base, así que también lee este archivo — deben coincidir siempre.
#
# Separado de backend/.env a propósito: el contenedor de postgres solo debe
# recibir estas 3 variables, no las API keys/secretos de JWT que vive en
# backend/.env (principio de menor privilegio — si el contenedor de postgres
# se ve comprometido, no expone secretos que no necesita).
#
# Copiá este archivo a `.env` en la raíz del repo. En cualquier ambiente que
# no sea desarrollo local, usá un POSTGRES_PASSWORD real (no "postgres").
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=imagineapps
