PORT=3001
NODE_ENV=development

DB_HOST=postgres
DB_PORT=5432
# Credenciales (POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB) NO van en este
# archivo: viven en el `.env` de la raíz del repo (ver `.env.example` ahí), que
# el servicio `postgres` de docker-compose.yml usa vía env_file para no
# necesitar (ni duplicar) credenciales hardcodeadas en el propio compose file.
# Este backend las recibe del mismo root `.env`.

# --- IA / RAG ---
# Proveedor usado para GENERAR la respuesta sugerida: "openai" o "anthropic".
AI_PROVIDER=openai
# API key del proveedor elegido arriba (OpenAI o Anthropic, según AI_PROVIDER).
AI_API_KEY=
# Modelo de chat. Ejemplos: gpt-4o-mini / gpt-4o (OpenAI), claude-3-5-haiku-latest / claude-3-5-sonnet-latest (Anthropic).
AI_MODEL=gpt-4o-mini

# Los embeddings (vectorización de los manuales y de la pregunta) SIEMPRE usan
# OpenAI, porque Anthropic no ofrece una API de embeddings.
# - Si AI_PROVIDER=openai, se reutiliza AI_API_KEY y este valor puede quedar vacío.
# - Si AI_PROVIDER=anthropic, hay que configurar esta key aparte solo para vectorizar.
OPENAI_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

REDIS_URL=redis://redis:6379
REDIS_INDEX_NAME=manuales_idx

# Estrategia para obtener category/ai_suggested_response/confidence_score:
# - "structured" (default): un único llamado con Structured Output/function calling.
# - "separate": RAG + clasificador como dos llamadas independientes (comportamiento original).
AI_ANALYSIS_STRATEGY=structured

# A partir de qué confidence_score (0-1) se considera que la IA "resolvió" el
# ticket (status RESOLVIENDO_IA en vez de PENDIENTE_AGENTE).
AI_CONFIDENCE_THRESHOLD=0.7

# --- Auth (JWT) ---
# Secretos para firmar tokens de acceso/refresh. Deben ser distintos entre sí
# y valores largos/aleatorios en cualquier ambiente real (ej. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
